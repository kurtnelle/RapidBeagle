#!/bin/sh
# S39-usb-gadget — create the USB-gadget composite that exposes usb0
# Runs BEFORE S40-network so usb0 already exists when ifup runs.
#
# Composition: RNDIS (for Windows hosts) + ECM (for Linux/macOS hosts).
# Both functions are placed in configuration #1; the host driver picks one.
# After binding, the kernel creates the network interface "usb0".
#
# To disable: chmod -x /etc/init.d/S39-usb-gadget

CONFIGFS=/sys/kernel/config
GADGET=$CONFIGFS/usb_gadget/g1
UDC_PATH=/sys/class/udc

start() {
    # Mount configfs if not already
    if ! mountpoint -q $CONFIGFS 2>/dev/null; then
        mkdir -p $CONFIGFS
        mount -t configfs none $CONFIGFS || {
            echo "S39-usb-gadget: configfs mount failed"
            return 1
        }
    fi

    # Make sure libcomposite is available (built-in or modprobe)
    [ -d $CONFIGFS/usb_gadget ] || modprobe libcomposite 2>/dev/null

    if [ ! -d $CONFIGFS/usb_gadget ]; then
        echo "S39-usb-gadget: configfs/usb_gadget unavailable — kernel missing CONFIG_USB_LIBCOMPOSITE?"
        return 1
    fi

    # Skip if already created
    if [ -d $GADGET ]; then
        echo "S39-usb-gadget: gadget already exists, skipping"
        return 0
    fi

    mkdir -p $GADGET || return 1
    cd $GADGET || return 1

    # Identify ourselves to the host
    echo 0x1d6b > idVendor          # Linux Foundation
    echo 0x0104 > idProduct         # Multifunction Composite Gadget
    echo 0x0100 > bcdDevice
    echo 0x0200 > bcdUSB
    echo 0xEF   > bDeviceClass      # Miscellaneous (allows IAD)
    echo 0x02   > bDeviceSubClass
    echo 0x01   > bDeviceProtocol

    mkdir -p strings/0x409
    echo "rapidbeagle-$(cat /sys/class/net/eth0/address 2>/dev/null | tr -d : || echo 000000)" > strings/0x409/serialnumber
    echo "RapidBeagle"           > strings/0x409/manufacturer
    echo "RapidBeagle USB Gadget" > strings/0x409/product

    # Configuration 1
    mkdir -p configs/c.1/strings/0x409
    echo "RNDIS + ECM" > configs/c.1/strings/0x409/configuration
    echo 250           > configs/c.1/MaxPower

    # OS descriptors so Windows auto-binds RNDIS
    echo 1       > os_desc/use
    echo 0xcd    > os_desc/b_vendor_code
    echo MSFT100 > os_desc/qw_sign

    # RNDIS function (Windows)
    mkdir -p functions/rndis.usb0
    echo RNDIS    > functions/rndis.usb0/os_desc/interface.rndis/compatible_id
    echo 5162001  > functions/rndis.usb0/os_desc/interface.rndis/sub_compatible_id 2>/dev/null || true
    ln -sf functions/rndis.usb0 configs/c.1/
    ln -sf configs/c.1 os_desc/

    # ECM function (Linux/macOS)
    mkdir -p functions/ecm.usb0
    ln -sf functions/ecm.usb0 configs/c.1/

    # Bind to the first available USB Device Controller
    UDC=$(ls $UDC_PATH 2>/dev/null | head -n1)
    if [ -z "$UDC" ]; then
        echo "S39-usb-gadget: no UDC available in $UDC_PATH — USB controller not bound"
        return 1
    fi
    echo "$UDC" > UDC
    echo "S39-usb-gadget: bound to UDC '$UDC'"

    # Bring the resulting usb0 interface up immediately. The interface only
    # appears AFTER UDC binding above, so /etc/network/interfaces 'allow-hotplug'
    # does not fire (the kernel does not emit a hotplug event for configfs-
    # created interfaces — it just adds them). Trigger ifup explicitly.
    if [ -e /sys/class/net/usb0 ]; then
        ifup usb0 >/dev/null 2>&1 || true
        echo "S39-usb-gadget: usb0 brought up"
    fi
}

stop() {
    if [ ! -d $GADGET ]; then
        return 0
    fi
    cd $GADGET || return 0
    # Unbind first — required before removing functions
    echo "" > UDC 2>/dev/null

    rm -f configs/c.1/rndis.usb0 configs/c.1/ecm.usb0 os_desc/c.1
    rmdir configs/c.1/strings/0x409 2>/dev/null
    rmdir configs/c.1                2>/dev/null
    rmdir functions/rndis.usb0       2>/dev/null
    rmdir functions/ecm.usb0         2>/dev/null
    rmdir strings/0x409              2>/dev/null
    cd /
    rmdir $GADGET 2>/dev/null
}

case "$1" in
    start)   start ;;
    stop)    stop ;;
    restart) stop; start ;;
    *) echo "Usage: $0 {start|stop|restart}"; exit 1 ;;
esac

exit 0
